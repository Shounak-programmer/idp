# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update with your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/idp_db
MONGODB_URL=mongodb://localhost:27017/idp_mongo
DATABASE_DEBUG=False

# ============================================
# MQTT BROKER CONFIGURATION
# ============================================
MQTT_BROKER_URL=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=admin
MQTT_PASSWORD=password
MQTT_KEEPALIVE=60

# ============================================
# FIREBASE CONFIGURATION
# ============================================
FIREBASE_CONFIG_PATH=./shared/config/firebase_config.json
FIREBASE_DB_URL=https://your-project.firebaseio.com

# ============================================
# BACKEND API CONFIGURATION
# ============================================
FLASK_ENV=development
FLASK_DEBUG=True
API_HOST=0.0.0.0
API_PORT=5000
API_SECRET_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ============================================
# GPS & LOCATION SERVICES
# ============================================
GPS_DEVICE=/dev/ttyUSB0  # Serial port for GPS module (Linux/Mac)
GPS_BAUDRATE=9600
GSM_MODULE_ENABLED=True
LOCATION_UPDATE_INTERVAL=5  # seconds

# ============================================
# GOOGLE MAPS & ROUTE OPTIMIZATION
# ============================================
GOOGLE_MAPS_API_KEY=your-api-key-here
OPENSTREETMAP_ENABLED=True
ROUTE_OPTIMIZATION_ENABLED=True

# ============================================
# VEHICLE DETECTION (YOLOv8)
# ============================================
YOLO_MODEL_PATH=./module1_ambulance_traffic/vehicle_detection/models/best.pt
CONFIDENCE_THRESHOLD=0.5
CAMERA_SOURCE=0  # 0 for default webcam, or video file path
DETECTION_FPS=30

# ============================================
# TRAFFIC SIGNAL COMMUNICATION
# ============================================
SIGNAL_DETECTION_RADIUS_KM=10
SIGNAL_PRIORITY_DURATION_SECONDS=120
SIGNAL_CONTROL_PROTOCOL=MQTT  # or FIREBASE

# ============================================
# HORNLESS COMMUNICATION (Module 2)
# ============================================
V2V_COMMUNICATION_TYPE=BLUETOOTH  # BLUETOOTH, ULTRASONIC, or IR
V2V_BROADCAST_POWER=HIGH
V2V_RANGE_METERS=50
SPATIAL_AUDIO_ENABLED=True
AUDIO_OUTPUT_DEVICE=default

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ============================================
# HARDWARE & IOT
# ============================================
ESP32_PORT=/dev/ttyUSB0
ESP32_BAUDRATE=115200
RASPBERRY_PI_IP=192.168.1.100
ULTRASONIC_SENSOR_GPIO_TRIGGER=23
ULTRASONIC_SENSOR_GPIO_ECHO=24

# ============================================
# TESTING & SIMULATION
# ============================================
SIMULATION_MODE=False
MOCK_GPS_DATA=False
MOCK_CAMERA_FEED=False
TEST_DATABASE_URL=sqlite:///test.db

# ============================================
# PERFORMANCE & MONITORING
# ============================================
ENABLE_PERFORMANCE_MONITORING=True
PROFILING_ENABLED=False
MAX_CONCURRENT_DETECTIONS=5
BATCH_PROCESSING=True
BATCH_SIZE=32

# ============================================
# SECURITY
# ============================================
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENABLE_HTTPS=False
SSL_CERTIFICATE_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem
